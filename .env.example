# AZ-Chat 后端环境变量
# 复制此文件为 .env 并填写实际值

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=azchat

# JWT 密钥（请生成随机字符串替换）
JWT_SECRET=your_jwt_secret_here

# 主密钥（请生成随机字符串替换）
MASTER_KEY=your_master_key_here

# 服务器端口
PORT=5001

# 短信服务 URL
SMS_URL=your_sms_service_url

# 默认管理员 ID
DEFAULT_ADMIN_ID=10001

# CORS 允许来源
CORS_ORIGINS=*

# 极光推送配置
JPUSH_APP_KEY=your_jpush_app_key
JPUSH_MASTER_SECRET=your_jpush_master_secret
